---
import { ArrowDownToLine, ArrowRight, Github, Linkedin, Mail } from 'lucide-astro';
import SiteHeader from '../components/SiteHeader.astro';
import {
	certifications,
	contactLinks,
	education,
	projects,
	specialties,
	stackGroups,
	uiCopy,
	workflow,
} from '../content/portfolio';
import Layout from '../layouts/Layout.astro';

const copy = uiCopy.es;
const projectActionLabel = uiCopy.es.projectAction;
const projectActionLabelEn = uiCopy.en.projectAction;
---

<Layout title={copy.pageTitle}>
	<div id="top" class="portfolio-shell">
		<SiteHeader />

		<main>
			<section class="hero section-grid" aria-labelledby="hero-title">
				<img class="neo-background" src="/neo-1.webp" alt="" aria-hidden="true" />
				<div class="neo-shine" aria-hidden="true"></div>

				<div class="hero-copy">
					<p class="eyebrow" data-i18n="heroBadge">{copy.heroBadge}</p>
					<!--<p class="role" data-i18n="heroRole">{copy.heroRole}</p> -->
					<h1 id="hero-title" data-i18n="heroName">{copy.heroName}</h1>
					<p class="slogan" data-i18n="heroTitle">{copy.heroTitle}</p>
					<p class="lead" data-i18n="heroSummary">{copy.heroSummary}</p>

					<div class="hero-actions" aria-label="Acciones principales">
						<a class="button button-primary" href="#projects">
							<span data-i18n="heroPrimary">{copy.heroPrimary}</span>
							<ArrowRight size={18} aria-hidden="true" />
						</a>
						<a class="button button-secondary" href="/miguel-gonzalez-santillan-cv.docx" download>
							<ArrowDownToLine size={18} aria-hidden="true" />
							<span data-i18n="heroCv">{copy.heroCv}</span>
						</a>
						<a class="button button-secondary" href="#contact">
							<Mail size={18} aria-hidden="true" />
							<span data-i18n="heroContact">{copy.heroContact}</span>
						</a>
					</div>
				</div>

				<div class="hero-visual">
					<img class="hero-photo" src="/foto_pose.jpeg" alt="Miguel Angel Gonzalez Santillan con su titulo universitario" />
					<aside class="hero-panel" aria-label="Resumen del perfil">
						<div>
							<span data-i18n="heroMetricFocus">{copy.heroMetricFocus}</span>
							<strong data-i18n="heroMetricFocusText">{copy.heroMetricFocusText}</strong>
						</div>
						<div>
							<span data-i18n="heroMetricTools">{copy.heroMetricTools}</span>
							<strong data-i18n="heroMetricToolsText">{copy.heroMetricToolsText}</strong>
						</div>
					</aside>
				</div>
			</section>

			<section id="about" class="content-section section-grid neo-section neo-section-about" aria-labelledby="about-title">
				<img class="neo-decor neo-decor-about" src="/neo-2.webp" alt="" aria-hidden="true" />
				<div class="neo-decor-shine neo-decor-shine-about" aria-hidden="true"></div>
				<div class="section-heading">
					<p class="eyebrow" data-i18n="aboutEyebrow">{copy.aboutEyebrow}</p>
					<h2 id="about-title" data-i18n="aboutTitle">{copy.aboutTitle}</h2>
				</div>
				<div class="section-body">
					<p data-i18n="aboutBody">{copy.aboutBody}</p>
					<blockquote data-i18n="aboutQuote">{copy.aboutQuote}</blockquote>
				</div>
			</section>

			<section id="education" class="content-section education-section" aria-labelledby="education-title">
				<div class="section-heading wide">
					<p class="eyebrow" data-i18n="educationEyebrow">{copy.educationEyebrow}</p>
					<h2 id="education-title" data-i18n="educationTitle">{copy.educationTitle}</h2>
				</div>

				<div class="education-layout">
					<div class="education-column">
						<h3 data-i18n="educationStudiesLabel">{copy.educationStudiesLabel}</h3>
						<div class="education-list">
							{education.map((item) => (
								<article class="education-card">
									<div class="education-card-header">
										<div>
											<h4 data-lang-es={item.degree.es} data-lang-en={item.degree.en}>{item.degree.es}</h4>
											<p data-lang-es={item.institution.es} data-lang-en={item.institution.en}>{item.institution.es}</p>
										</div>
										<span data-lang-es={item.period.es} data-lang-en={item.period.en}>{item.period.es}</span>
									</div>
									<dl class="education-details">
										<div>
											<dt data-i18n="educationFocusLabel">{copy.educationFocusLabel}</dt>
											<dd data-lang-es={item.focus.es} data-lang-en={item.focus.en}>{item.focus.es}</dd>
										</div>
									</dl>
								</article>
							))}
						</div>
					</div>

					<div class="education-column">
						<h3 data-i18n="educationCertificationsLabel">{copy.educationCertificationsLabel}</h3>
						<div class="education-list compact">
							{certifications.map((item) => (
								<article class="education-card">
									<div class="education-card-header">
										<div>
											<h4 data-lang-es={item.name.es} data-lang-en={item.name.en}>{item.name.es}</h4>
											<p>{item.issuer}</p>
										</div>
										<span data-lang-es={item.period.es} data-lang-en={item.period.en}>{item.period.es}</span>
									</div>
									<dl class="education-details">
										<div>
											<dt data-i18n="educationSkillsLabel">{copy.educationSkillsLabel}</dt>
											<dd data-lang-es={item.skills.es} data-lang-en={item.skills.en}>{item.skills.es}</dd>
										</div>
									</dl>
								</article>
							))}
						</div>
					</div>
				</div>
			</section>

			<section id="specialties" class="content-section neo-section neo-section-specialties" aria-labelledby="specialties-title">
				<img class="neo-decor neo-decor-specialties" src="/neo-3.webp" alt="" aria-hidden="true" />
				<div class="neo-decor-shine neo-decor-shine-specialties" aria-hidden="true"></div>
				<div class="section-heading wide">
					<p class="eyebrow" data-i18n="specialtiesEyebrow">{copy.specialtiesEyebrow}</p>
					<h2 id="specialties-title" data-i18n="specialtiesTitle">{copy.specialtiesTitle}</h2>
				</div>

				<div class="specialty-grid">
					{specialties.map((item) => (
						<article class="specialty-card">
							<h3 data-lang-es={item.title.es} data-lang-en={item.title.en}>{item.title.es}</h3>
							<p data-lang-es={item.description.es} data-lang-en={item.description.en}>{item.description.es}</p>
							<ul class="badge-list" aria-label="Tecnologias relacionadas">
								{item.technologies.map((technology) => (
									<li>
										<img src={technology.src} alt={technology.label} loading="lazy" />
									</li>
								))}
							</ul>
						</article>
					))}
				</div>
			</section>

			<section id="projects" class="content-section" aria-labelledby="projects-title">
				<div class="section-heading wide">
					<p class="eyebrow" data-i18n="projectsEyebrow">{copy.projectsEyebrow}</p>
					<h2 id="projects-title" data-i18n="projectsTitle">{copy.projectsTitle}</h2>
				</div>

				<div class="project-grid">
					{projects.map((project) => (
						<article class="project-card">
							<div class="project-card-header">
								<h3>{project.name}</h3>
								<a class="details-link" href="#contact" data-lang-es={projectActionLabel} data-lang-en={projectActionLabelEn}>{projectActionLabel}</a>
							</div>
							<dl class="project-details">
								<div>
									<dt data-i18n="projectProblem">{copy.projectProblem}</dt>
									<dd data-lang-es={project.problem.es} data-lang-en={project.problem.en}>{project.problem.es}</dd>
								</div>
								<div>
									<dt data-i18n="projectSolution">{copy.projectSolution}</dt>
									<dd data-lang-es={project.solution.es} data-lang-en={project.solution.en}>{project.solution.es}</dd>
								</div>
								<div>
									<dt data-i18n="projectValue">{copy.projectValue}</dt>
									<dd data-lang-es={project.value.es} data-lang-en={project.value.en}>{project.value.es}</dd>
								</div>
							</dl>
							<div class="tech-row">
								<span data-i18n="projectTech">{copy.projectTech}</span>
								<ul class="tag-list compact">
									{project.technologies.map((technology) => <li>{technology}</li>)}
								</ul>
							</div>
						</article>
					))}
				</div>
			</section>

			<section id="experience" class="content-section section-grid neo-section neo-section-experience" aria-labelledby="experience-title">
				<img class="neo-decor neo-decor-experience" src="/neo-4.webp" alt="" aria-hidden="true" />
				<div class="neo-decor-shine neo-decor-shine-experience" aria-hidden="true"></div>
				<div class="section-heading">
					<p class="eyebrow" data-i18n="experienceEyebrow">{copy.experienceEyebrow}</p>
					<h2 id="experience-title" data-i18n="experienceTitle">{copy.experienceTitle}</h2>
				</div>
				<div class="experience-card">
					<p data-i18n="experienceBody">{copy.experienceBody}</p>
					<ul class="experience-list">
						<li>Backend</li>
						<li>APIs</li>
						<li>SQL</li>
						<li>Interfaces administrativas</li>
						<li>Mantenimiento evolutivo</li>
					</ul>
				</div>
			</section>

			<section class="content-section" aria-labelledby="stack-title">
				<div class="section-heading wide">
					<p class="eyebrow" data-i18n="stackEyebrow">{copy.stackEyebrow}</p>
					<h2 id="stack-title" data-i18n="stackTitle">{copy.stackTitle}</h2>
				</div>

				<div class="stack-grid">
					{stackGroups.map((group) => (
						<div class="stack-group">
							<h3 data-lang-es={group.label.es} data-lang-en={group.label.en}>{group.label.es}</h3>
							<ul>
								{group.items.map((item) => <li>{item}</li>)}
							</ul>
						</div>
					))}
				</div>
			</section>

			<section class="content-section section-grid" aria-labelledby="workflow-title">
				<div class="section-heading">
					<p class="eyebrow" data-i18n="workflowEyebrow">{copy.workflowEyebrow}</p>
					<h2 id="workflow-title" data-i18n="workflowTitle">{copy.workflowTitle}</h2>
				</div>
				<ol class="workflow-list">
					{workflow.map((item) => <li data-lang-es={item.es} data-lang-en={item.en}>{item.es}</li>)}
				</ol>
			</section>

			<section id="contact" class="contact-section" aria-labelledby="contact-title">
				<p class="eyebrow" data-i18n="contactEyebrow">{copy.contactEyebrow}</p>
				<h2 id="contact-title" data-i18n="contactTitle">{copy.contactTitle}</h2>
				<p data-i18n="contactBody">{copy.contactBody}</p>
				<div class="contact-actions">
					<a class="button button-primary" href={contactLinks[0].href}>
						<Mail size={18} aria-hidden="true" />
						<span data-i18n={contactLinks[0].key}>{copy.contactEmail}</span>
					</a>
					<a class="button button-secondary" href={contactLinks[1].href} target="_blank" rel="noreferrer">
						<Github size={18} aria-hidden="true" />
						<span data-i18n={contactLinks[1].key}>{copy.contactGithub}</span>
					</a>
					<a class="button button-secondary" href={contactLinks[2].href} target="_blank" rel="noreferrer">
						<Linkedin size={18} aria-hidden="true" />
						<span data-i18n={contactLinks[2].key}>{copy.contactLinkedin}</span>
					</a>
				</div>
			</section>
		</main>
	</div>
</Layout>
<style>
	.portfolio-shell {
		width: min(1180px, calc(100% - 2rem));
		max-width: 100%;
		margin: 0 auto;
		overflow-x: visible;
	}

	main {
		display: grid;
		gap: clamp(4rem, 8vw, 7rem);
		padding: 2rem 0 4rem;
	}

	.section-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.92fr) minmax(20rem, 1fr);
		gap: clamp(2rem, 6vw, 5rem);
		align-items: start;
	}

	.hero {
		--neo-right: -12rem;
		--neo-top: 70%;
		--neo-width: clamp(20rem, 36vw, 34rem);
		--neo-rotate: 8deg;
		--neo-scale: 1.3;
		--neo-opacity: 0.34;
		--neo-shine-x: 50%;
		--neo-shine-y: 50%;
		position: relative;
		overflow-x: visible;
		isolation: isolate;
		min-height: calc(100vh - 7rem);
		align-items: center;
		padding: clamp(0.25rem, 1vw, 0.5rem) 0 clamp(2.5rem, 7vw, 6rem);
	}

	.neo-background {
		position: absolute;
		top: var(--neo-top);
		right: var(--neo-right);
		z-index: 0;
		width: var(--neo-width);
		height: auto;
		opacity: var(--neo-opacity);
		pointer-events: none;
		transform: translateY(-50%) rotate(var(--neo-rotate)) scale(var(--neo-scale));
		transform-origin: center;
		filter:
			saturate(0.2)
			contrast(1.16)
			brightness(1.08)
			drop-shadow(0 14px 34px rgba(180, 190, 198, 0.38));
		transition:
			filter 220ms ease,
			opacity 220ms ease;
	}

	:global(:root[data-theme='light']) .neo-background {
		filter:
			invert(1)
			hue-rotate(180deg)
			saturate(0.35)
			contrast(1.08)
			brightness(1.06)
			drop-shadow(0 14px 34px rgba(18, 22, 26, 0.18));
	}
	.neo-shine {
		position: absolute;
		top: var(--neo-top);
		right: var(--neo-right);
		z-index: 0;
		width: var(--neo-width);
		aspect-ratio: 1024 / 1536;
		opacity: 0;
		pointer-events: none;
		transform: translateY(-50%) rotate(var(--neo-rotate)) scale(var(--neo-scale));
		transform-origin: center;
		background:
			radial-gradient(
				circle at var(--neo-shine-x) var(--neo-shine-y),
				rgba(255, 255, 255, 0.40) 0 7%,
				rgba(220, 228, 235, 0.7) 8% 15%,
				rgba(180, 190, 198, 0.26) 20%,
				transparent 20%
			);
		filter: blur(1px) drop-shadow(0 0 18px rgba(255, 255, 255, 0.56));
		-webkit-mask-image: url('/neo-1.webp');
		mask-image: url('/neo-1.webp');
		-webkit-mask-size: 100% 100%;
		mask-size: 100% 100%;
		-webkit-mask-repeat: no-repeat;
		mask-repeat: no-repeat;
		transition: opacity 160ms ease;
	}

	.hero:hover .neo-shine,
	.hero:focus-within .neo-shine {
		opacity: 0.6;
	}

	.hero-copy,
	.hero-visual {
		position: relative;
		z-index: 1;
	}

	.eyebrow {
		margin: 0 0 1rem;
		color: var(--muted);
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.slogan {
		margin: 0 0 0.4rem;
		font-size: clamp(1.05rem, 2vw, 1.35rem);
		font-weight: 800;
	}

	.role {
		margin: 0 0 1.4rem;
		color: var(--muted);
		font-weight: 700;
	}

	h1,
	h2,
	h3,
	h4,
	p {
		letter-spacing: 0;
	}

	h1 {
		max-width: 13ch;
		margin: 0;
		font-size: clamp(3.1rem, 7vw, 6.5rem);
		line-height: 0.96;
	}

	h2 {
		margin: 0;
		font-size: clamp(2rem, 4vw, 3.8rem);
		line-height: 1.02;
	}

	h3 {
		margin: 0;
		font-size: 1.08rem;
		line-height: 1.25;
	}

	h4 {
		margin: 0;
		font-size: 1rem;
		line-height: 1.3;
	}

	.lead,
	.section-body p,
	.experience-card p,
	.contact-section p {
		color: var(--muted);
		font-size: clamp(1rem, 1.7vw, 1.2rem);
		line-height: 1.7;
	}

	.lead {
		max-width: 43rem;
		margin: 1.4rem 0 0;
	}

	.hero-actions,
	.contact-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 2rem;
	}

	.button {
		display: inline-flex;
		box-sizing: border-box;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		max-width: 100%;
		min-height: 3rem;
		min-width: 0;
		padding: 0 1rem;
		border-radius: var(--radius-sm);
		font-weight: 800;
		text-align: center;
		text-decoration: none;
		transition:
			transform 160ms ease,
			border-color 160ms ease,
			background-color 160ms ease;
	}

	.button:hover,
	.button:focus-visible {
		transform: translateY(-1px);
	}

	.button-primary {
		border: 1px solid var(--text);
		background: var(--text);
		color: var(--background);
	}

	.button-secondary {
		border: 1px solid var(--border);
		background: var(--surface);
		color: var(--text);
	}

	.hero-visual {
		--hero-panel-offset: clamp(7rem, 4vw, 3rem);
		position: relative;
		display: grid;
		align-items: end;
		min-height: clamp(27rem, 44vw, 34rem);
		padding: clamp(11rem, 20vw, 15rem) 0 var(--hero-panel-offset) clamp(1rem, 4vw, 3rem);
	}

	.hero-photo {
		position: absolute;
		top: 0;
		right: clamp(80%);
		z-index: 0;
		width: min(76%, 22rem);
		aspect-ratio: 0.76;
		border: 3px solid color-mix(in srgb, var(--accent-green) 58%, var(--surface));
		border-radius: 60%;
		object-fit: cover;
		object-position: 50% 36%;
		box-shadow:
			0 26px 70px var(--accent-green-shadow),
			0 0 0 1rem color-mix(in srgb, var(--accent-green) 10%, transparent);
	}

	.hero-panel,
	.education-card,
	.specialty-card,
	.project-card,
	.experience-card,
	.stack-group,
	.contact-section {
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		background: var(--surface);
		box-shadow: var(--shadow);
	}

	.hero-panel {
		position: relative;
		z-index: 1;
		display: grid;
		gap: 0;
		padding: 0.5rem;
		background: color-mix(in srgb, var(--surface) 40%, transparent);
		backdrop-filter: blur(14px);
		border-color: color-mix(in srgb, var(--border) 42%, transparent);
		transform: translateY(var(--hero-panel-offset));
	}

	.hero-panel div {
		padding: 1.15rem;
		border-radius: var(--radius-sm);
	}

	.hero-panel div + div {
		border-top: 1px solid var(--border);
	}

	.hero-panel span,
	.tech-row span {
		display: block;
		margin-bottom: 0.35rem;
		color: var(--muted);
		font-size: 0.78rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.hero-panel strong {
		display: block;
		font-size: clamp(1.05rem, 2vw, 1.45rem);
		line-height: 1.28;
	}

	.content-section {
		scroll-margin-top: 6rem;
	}

	.neo-section {
		--decor-width: clamp(18rem, 34vw, 32rem);
		--decor-top: 50%;
		--decor-right: auto;
		--decor-bottom: auto;
		--decor-left: auto;
		--decor-rotate: 8deg;
		--decor-scale: 1.2;
		--decor-opacity: 0.28;
		--decor-shine-x: 50%;
		--decor-shine-y: 50%;
		--decor-mask: url('/neo-2.webp');
		position: relative;
		overflow-x: visible;
		isolation: isolate;
	}

	.neo-decor,
	.neo-decor-shine {
		position: absolute;
		top: var(--decor-top);
		right: var(--decor-right);
		bottom: var(--decor-bottom);
		left: var(--decor-left);
		z-index: 0;
		width: var(--decor-width);
		pointer-events: none;
		transform: translateY(-50%) rotate(var(--decor-rotate)) scale(var(--decor-scale));
		transform-origin: center;
		transition:
			filter 220ms ease,
			opacity 220ms ease;
	}

	.neo-decor {
		height: auto;
		opacity: var(--decor-opacity);
		filter:
			saturate(0.2)
			contrast(1.16)
			brightness(1.08)
			drop-shadow(0 14px 34px rgba(180, 190, 198, 0.34));
	}

	:global(:root[data-theme='light']) .neo-decor {
		filter:
			invert(1)
			hue-rotate(180deg)
			saturate(0.35)
			contrast(1.08)
			brightness(1.06)
			drop-shadow(0 14px 34px rgba(18, 22, 26, 0.16));
	}

	.neo-decor-shine {
		aspect-ratio: 1024 / 1536;
		opacity: 0;
		background:
			radial-gradient(
				circle at var(--decor-shine-x) var(--decor-shine-y),
				rgba(255, 255, 255, 0.40) 0 7%,
				rgba(220, 228, 235, 0.7) 8% 15%,
				rgba(180, 190, 198, 0.26) 20%,
				transparent 20%
			);
		filter: blur(1px) drop-shadow(0 0 18px rgba(255, 255, 255, 0.56));
		-webkit-mask-image: var(--decor-mask);
		mask-image: var(--decor-mask);
		-webkit-mask-size: 100% 100%;
		mask-size: 100% 100%;
		-webkit-mask-repeat: no-repeat;
		mask-repeat: no-repeat;
		transition: opacity 160ms ease;
	}


	.neo-section:hover .neo-decor-shine,
	.neo-section:focus-within .neo-decor-shine {
		opacity: 0.6;
	}

	.neo-section > :not(.neo-decor):not(.neo-decor-shine) {
		position: relative;
		z-index: 1;
	}

	.neo-section-about {
		--decor-top: 150%;
		--decor-right: -25rem;
		--decor-rotate: -8deg;
		--decor-mask: url('/neo-2.webp');
	}

	.neo-section-specialties {
		--decor-top: 100%;
