---
interface Props {
	title?: string;
}

const { title = 'Miguel Angel Gonzalez Santillan | Desarrollador Full Stack' } = Astro.props;
---

<!doctype html>
<html lang="es" data-theme="light">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="color-scheme" content="light dark" />
		<title>{title}</title>
		<script is:inline>
			(() => {
				const storageKeys = {
					language: 'portfolio-language',
					theme: 'portfolio-theme',
				};
				const supportedLanguages = ['en', 'es'];
				const getInitialLanguage = () => {
					const storedLanguage = localStorage.getItem(storageKeys.language);
					if (supportedLanguages.includes(storedLanguage)) return storedLanguage;

					return navigator.language?.toLowerCase().startsWith('es') ? 'es' : 'en';
				};
				const getInitialTheme = () => {
					const storedTheme = localStorage.getItem(storageKeys.theme);
					if (storedTheme === 'light' || storedTheme === 'dark') return storedTheme;

					return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
				};

				const language = getInitialLanguage();
				const theme = getInitialTheme();

				document.documentElement.lang = language;
				document.documentElement.dataset.theme = theme;
				document.documentElement.style.colorScheme = theme;
			})();
		</script>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	:root {
		--background: #f7f7f5;
		--surface: #ffffff;
		--surface-subtle: #f0f0ed;
		--control-background: rgba(255, 255, 255, 0.78);
		--text: #171717;
		--muted: #626262;
		--border: #d9d9d4;
		--accent-green: #0f9f7a;
		--accent-green-shadow: rgba(15, 159, 122, 0.34);
		--shadow: 0 18px 60px rgba(0, 0, 0, 0.08);
		--radius-xs: 0.35rem;
		--radius-sm: 0.5rem;
		--radius-md: 0.75rem;
		--radius-pill: 999px;
	}

	:root[data-theme='dark'] {
		--background: #111111;
		--surface: #181818;
		--surface-subtle: #222222;
		--control-background: rgba(24, 24, 24, 0.78);
		--text: #f3f3f0;
		--muted: #b6b6ae;
		--border: #333330;
		--accent-green: #1fc79a;
		--accent-green-shadow: rgba(31, 199, 154, 0.26);
		--shadow: 0 18px 60px rgba(0, 0, 0, 0.34);
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		overflow-x: hidden;
		scroll-behavior: smooth;
	}

	html {
		background: var(--background);
		color: var(--text);
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
	}

	body {
		position: relative;
		background: var(--background);
		color: var(--text);
		transition:
			background-color 180ms ease,
			color 180ms ease;
	}

	:global(*),
	:global(*::before),
	:global(*::after) {
		box-sizing: border-box;
	}

	::selection {
		background: var(--text);
		color: var(--background);
	}

	button,
	a {
		-webkit-tap-highlight-color: transparent;
	}
</style>