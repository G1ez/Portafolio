---
import PreferenceControls from './PreferenceControls.astro';
import { navItems, uiCopy } from '../content/portfolio';
---

<header class="site-header">
	<a class="brand" href="#top" data-aria-es={uiCopy.es.brandLabel} data-aria-en={uiCopy.en.brandLabel} aria-label={uiCopy.es.brandLabel}>
		<span>G1ez</span>
	</a>

	<nav class="main-nav" data-aria-es={uiCopy.es.navLabel} data-aria-en={uiCopy.en.navLabel} aria-label={uiCopy.es.navLabel}>
		{navItems.map((item) => <a href={item.href} data-i18n={item.labelKey}>{uiCopy.es[item.labelKey]}</a>)}
	</nav>

	<PreferenceControls />
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1rem;
		padding: 1rem 0;
		background: color-mix(in srgb, var(--background) 88%, transparent);
		backdrop-filter: blur(18px);
	}

	.brand {
		display: inline-grid;
		place-items: center;
		color: var(--text);
		font-size: clamp(1.6rem, 3vw, 2.4rem);
		font-weight: 900;
		text-decoration: none;
		letter-spacing: 0;
	}

	.main-nav {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: clamp(0.75rem, 2vw, 1.5rem);
	}

	.main-nav a {
		color: var(--muted);
		font-size: 0.9rem;
		font-weight: 700;
		text-decoration: none;
		transition: color 160ms ease;
	}

	.main-nav a:hover,
	.main-nav a:focus-visible {
		color: var(--text);
	}

	@media (max-width: 980px) {
		.site-header {
			grid-template-columns: auto 1fr;
		}

		.main-nav {
			grid-column: 1 / -1;
			justify-content: flex-start;
			overflow-x: auto;
			padding-bottom: 0.25rem;
		}
	}

	@media (max-width: 720px) {
		.site-header {
			position: static;
			grid-template-columns: 1fr;
		}

		.main-nav {
			width: 100%;
		}
	}
</style>