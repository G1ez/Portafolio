---
import { Languages, Moon, Sun } from 'lucide-astro';
import { uiCopy } from '../content/portfolio';
---

<div class="preferences" data-aria-es={uiCopy.es.preferencesLabel} data-aria-en={uiCopy.en.preferencesLabel} aria-label={uiCopy.es.preferencesLabel}>
	<div class="control-group" data-aria-es={uiCopy.es.languageLabel} data-aria-en={uiCopy.en.languageLabel} aria-label={uiCopy.es.languageLabel}>
		<Languages size={18} aria-hidden="true" />
		<button type="button" class="segmented-button" data-language-option="es" aria-pressed="false">ES</button>
		<button type="button" class="segmented-button" data-language-option="en" aria-pressed="false">EN</button>
	</div>

	<button
		type="button"
		class="theme-toggle"
		data-theme-toggle
		data-aria-es={uiCopy.es.themeToggleLabel}
		data-aria-en={uiCopy.en.themeToggleLabel}
		aria-label={uiCopy.es.themeToggleLabel}
		aria-pressed="false"
	>
		<Sun class="sun-icon" size={18} aria-hidden="true" />
		<Moon class="moon-icon" size={18} aria-hidden="true" />
		<span data-theme-label>{uiCopy.es.themeLight}</span>
	</button>
</div>

<script define:vars={{ uiCopy }}>
	const storageKeys = {
		language: 'portfolio-language',
		theme: 'portfolio-theme',
	};

	const root = document.documentElement;
	const languageButtons = document.querySelectorAll('[data-language-option]');
	const themeToggle = document.querySelector('[data-theme-toggle]');
	const themeLabel = document.querySelector('[data-theme-label]');
	const themeQuery = window.matchMedia('(prefers-color-scheme: dark)');

	const getStoredLanguage = () => localStorage.getItem(storageKeys.language);
	const getStoredTheme = () => localStorage.getItem(storageKeys.theme);
	const getDeviceLanguage = () => (navigator.language?.toLowerCase().startsWith('es') ? 'es' : 'en');
	const getDeviceTheme = () => (themeQuery.matches ? 'dark' : 'light');
	const getActiveLanguage = () => {
		const storedLanguage = getStoredLanguage();
		return storedLanguage === 'en' || storedLanguage === 'es' ? storedLanguage : getDeviceLanguage();
	};
	const getActiveTheme = () => {
		const storedTheme = getStoredTheme();
		return storedTheme === 'light' || storedTheme === 'dark' ? storedTheme : getDeviceTheme();
	};

	const translateText = (language) => {
		const dictionary = uiCopy[language] ?? uiCopy.es;
		root.lang = language;
		document.title = dictionary.pageTitle;

		document.querySelectorAll('[data-i18n]').forEach((element) => {
			const key = element.getAttribute('data-i18n');
			if (!key || !dictionary[key]) return;
			element.textContent = dictionary[key];
		});

		document.querySelectorAll('[data-lang-es][data-lang-en]').forEach((element) => {
			const text = element.getAttribute(`data-lang-${language}`);
			if (text) element.textContent = text;
		});

		document.querySelectorAll('[data-aria-es][data-aria-en]').forEach((element) => {
			const label = element.getAttribute(`data-aria-${language}`);
			if (label) element.setAttribute('aria-label', label);
		});

		languageButtons.forEach((button) => {
			const isActive = button.getAttribute('data-language-option') === language;
			button.setAttribute('aria-pressed', String(isActive));
		});
	};

	const applyTheme = (theme) => {
		const language = getActiveLanguage();
		const dictionary = uiCopy[language] ?? uiCopy.es;
		root.dataset.theme = theme;
		root.style.colorScheme = theme;
		themeToggle?.setAttribute('aria-pressed', String(theme === 'dark'));
		if (themeLabel) themeLabel.textContent = theme === 'dark' ? dictionary.themeDark : dictionary.themeLight;
	};

	const refreshPreferences = () => {
		const language = getActiveLanguage();
		translateText(language);
		applyTheme(getActiveTheme());
	};

	languageButtons.forEach((button) => {
		button.addEventListener('click', () => {
			const language = button.getAttribute('data-language-option');
			if (language !== 'en' && language !== 'es') return;
			localStorage.setItem(storageKeys.language, language);
			refreshPreferences();
		});
	});

	themeToggle?.addEventListener('click', () => {
		const nextTheme = getActiveTheme() === 'dark' ? 'light' : 'dark';
		localStorage.setItem(storageKeys.theme, nextTheme);
		applyTheme(nextTheme);
	});

	themeQuery.addEventListener('change', () => {
		if (!getStoredTheme()) applyTheme(getDeviceTheme());
	});

	refreshPreferences();
</script>

<style>
	.preferences {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		flex-wrap: wrap;
	}

	.control-group,
	.theme-toggle {
		display: inline-flex;
		align-items: center;
		height: 2.5rem;
		gap: 0.3rem;
		border: 1px solid var(--border);
		background: var(--control-background);
		color: var(--text);
	}

	.control-group {
		padding: 0.2rem;
		border-radius: var(--radius-pill);
	}

	.control-group svg {
		margin-left: 0.55rem;
		color: var(--muted);
	}

	.segmented-button,
	.theme-toggle {
		font: inherit;
		font-size: 0.82rem;
		font-weight: 700;
		cursor: pointer;
	}

	.segmented-button {
		min-width: 2.35rem;
		height: 2rem;
		border: 0;
		border-radius: var(--radius-pill);
		background: transparent;
		color: var(--muted);
	}

	.segmented-button[aria-pressed='true'] {
		background: var(--text);
		color: var(--background);
	}

	.theme-toggle {
		min-width: 6.75rem;
		justify-content: center;
		border-radius: var(--radius-pill);
		padding: 0 0.85rem;
	}

	.theme-toggle svg {
		color: var(--text);
	}

	:root[data-theme='dark'] .sun-icon,
	:root[data-theme='light'] .moon-icon {
		display: none;
	}

	@media (max-width: 720px) {
		.preferences {
			width: 100%;
			justify-content: center;
		}

		.control-group,
		.theme-toggle {
			flex: 1 1 auto;
		}
	}
	@media (max-width: 420px) {
		.preferences {
			flex-direction: column;
			align-items: stretch;
		}

		.control-group,
		.theme-toggle {
			width: 100%;
		}
	}
</style>