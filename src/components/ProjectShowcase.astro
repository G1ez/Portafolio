---
import { ArrowRight, X } from 'lucide-astro';
const { projects, copy } = Astro.props;
const looks = [
 { code: 'SKY', label: { es: 'Plataforma SaaS', en: 'SaaS platform' }, tone: 'mint' },
 { code: 'ALB', label: { es: 'Finanzas y cobranza', en: 'Finance & collections' }, tone: 'violet' },
 { code: 'SIP', label: { es: 'Seguimiento operativo', en: 'Operations tracking' }, tone: 'amber' },
 { code: 'RED', label: { es: 'Comunidad institucional', en: 'Institutional community' }, tone: 'blue' },
];
---
<p class="intro" data-lang-es="Explora los proyectos y selecciona una tarjeta para ver el caso de estudio." data-lang-en="Drag the cards to explore. Select one to view the case study.">Explora los proyectos y selecciona una tarjeta para ver el caso de estudio.</p>
<div class="board" data-project-board>
{projects.map((project, index) => { const look = looks[index]; return <button class={`card ${look.tone}`} type="button" data-project-trigger={index} aria-haspopup="dialog"><span class="preview" aria-hidden="true"><i></i><b>{look.code}</b><em></em></span><span><small data-lang-es={look.label.es} data-lang-en={look.label.en}>{look.label.es}</small><strong>{project.name}</strong><span class="open" data-lang-es="Ver caso de estudio" data-lang-en="View case study">Ver caso de estudio <ArrowRight size={16} /></span></span></button> })}
</div>
{projects.map((project, index) => { const look = looks[index]; return <dialog class="dialog" data-project-dialog={index} aria-labelledby={`project-title-${index}`}><div class={`gallery ${look.tone}`} aria-hidden="true"><div><b>{look.code}</b><small>01</small></div><div><b>{look.code}</b><small>02</small></div><div><b>{look.code}</b><small>03</small></div></div><div class="body"><button class="close" type="button" data-project-close aria-label="Cerrar proyecto"><X size={20} /></button><p class="eyebrow" data-lang-es={look.label.es} data-lang-en={look.label.en}>{look.label.es}</p><h3 id={`project-title-${index}`}>{project.name}</h3><p class="about" data-lang-es={`Caso de estudio de ${project.name}: contexto, solución y valor entregado.`} data-lang-en={`${project.name} case study: context, solution, and delivered value.`}>Caso de estudio de {project.name}: contexto, solución y valor entregado.</p><dl><div><dt data-i18n="projectProblem">{copy.projectProblem}</dt><dd data-lang-es={project.problem.es} data-lang-en={project.problem.en}>{project.problem.es}</dd></div><div><dt data-i18n="projectSolution">{copy.projectSolution}</dt><dd data-lang-es={project.solution.es} data-lang-en={project.solution.en}>{project.solution.es}</dd></div><div><dt data-i18n="projectValue">{copy.projectValue}</dt><dd data-lang-es={project.value.es} data-lang-en={project.value.en}>{project.value.es}</dd></div></dl><div class="tech"><span data-i18n="projectTech">{copy.projectTech}</span><ul>{project.technologies.map((item) => <li>{item}</li>)}</ul></div></div></dialog> })}
<script>
const dialogs = document.querySelectorAll('[data-project-dialog]');
document.querySelectorAll('[data-project-trigger]').forEach((card) => card.addEventListener('click', () => dialogs[Number(card.dataset.projectTrigger)]?.showModal()));
dialogs.forEach((dialog) => { dialog.querySelector('[data-project-close]')?.addEventListener('click',()=>dialog.close()); dialog.addEventListener('click',(event)=>{ if(event.target === dialog) dialog.close(); }); });
</script>
<style>
.intro{margin:0 0 1.5rem;color:var(--muted)}.board{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));grid-auto-rows:11rem;gap:1rem;padding:1rem 0}.card{display:grid;gap:1rem;text-align:left;padding:.7rem;border:1px solid var(--border);border-radius:1rem;background:var(--surface);color:var(--text);box-shadow:var(--shadow);cursor:pointer;overflow:hidden;transition:transform .18s,box-shadow .18s,border-color .18s}.card:first-child{grid-column:span 2;grid-row:span 2}.card:nth-child(4){grid-column:span 2}.card:hover,.card:focus-visible{transform:translateY(-4px);border-color:var(--accent-green);box-shadow:0 24px 62px var(--accent-green-shadow)}.preview,.gallery{--accent:#20b987;background:linear-gradient(145deg,var(--accent),#10171b);color:#fff}.violet{--accent:#8656df}.amber{--accent:#d68532}.blue{--accent:#3183d8}.preview{position:relative;min-height:0;height:100%;border-radius:.65rem;overflow:hidden}.card:first-child .preview{min-height:0}.preview i{position:absolute;inset:1rem 1rem auto;height:.4rem;border-radius:99px;background:#fff5}.preview b{position:absolute;top:3rem;left:1.3rem;font-size:4rem;letter-spacing:-.12em}.preview em{position:absolute;left:1.3rem;right:1.3rem;bottom:1.2rem;height:3.5rem;background:repeating-linear-gradient(90deg,#fff 0 13%,transparent 13% 19%);clip-path:polygon(0 85%,20% 45%,38% 60%,58% 5%,78% 32%,100% 0,100% 100%,0 100%);opacity:.75}.card>span:last-child{display:grid;gap:.5rem;padding:.25rem .5rem}.card:first-child{grid-template-columns:1.18fr .82fr;align-items:stretch}.card:first-child .preview{height:auto}.card:nth-child(2) .preview,.card:nth-child(3) .preview,.card:nth-child(4) .preview{min-height:6rem}.card small,.tech>span{font-size:.72rem;text-transform:uppercase;letter-spacing:.08em;font-weight:800;color:var(--muted)}.card strong{font-size:1.15rem;line-height:1.25}.open{display:inline-flex;gap:.35rem;align-items:center;color:var(--accent-green);font-weight:800;font-size:.9rem}.dialog{width:min(880px,calc(100% - 2rem));padding:0;border:1px solid var(--border);border-radius:1rem;background:var(--surface);color:var(--text);box-shadow:0 24px 90px #0008}.dialog::backdrop{background:#0a0a0ab8;backdrop-filter:blur(5px)}.gallery{display:grid;grid-template-columns:1.35fr 1fr 1fr;gap:1rem;min-height:15rem;padding:1.25rem}.gallery div{display:flex;align-items:end;justify-content:space-between;padding:1rem;border:1px solid #fff4;border-radius:.5rem;background:#0003}.gallery div:nth-child(2){transform:translateY(1.5rem)}.gallery b{font-size:2rem}.body{position:relative;padding:clamp(1.5rem,4vw,3rem)}.body h3{font-size:clamp(1.55rem,4vw,2.4rem);padding-right:2.5rem}.close{position:absolute;right:1.2rem;top:1.2rem;border:0;background:transparent;color:var(--text);cursor:pointer}.about{line-height:1.6;color:var(--muted)}.body dl{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin:1.75rem 0}.body dl div{padding:1rem;border-radius:.6rem;background:var(--surface-subtle)}dt{font-size:.72rem;text-transform:uppercase;font-weight:900;color:var(--muted)}dd{margin:.45rem 0 0;line-height:1.5}.tech{display:grid;gap:.6rem}.tech ul{display:flex;gap:.5rem;flex-wrap:wrap;padding:0;margin:0;list-style:none}.tech li{padding:.35rem .6rem;border:1px solid var(--border);border-radius:99px;font-size:.85rem}@media(max-width:760px){.board{grid-template-columns:1fr;grid-auto-rows:auto}.card,.card:first-child,.card:nth-child(4){grid-column:span 1;grid-row:span 1}.card{cursor:pointer}.preview{height:12rem}.card:first-child{grid-template-columns:1fr}.card:first-child .preview{height:12rem}.body dl{grid-template-columns:1fr}.gallery{grid-template-columns:1fr 1fr}.gallery div:first-child{grid-column:span 2}.gallery div:nth-child(2){transform:none}}
</style>